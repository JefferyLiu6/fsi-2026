# Copy to .env and fill in the keys you want to use.
# At least one provider key is required (or Ollama must be running).

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google (Gemini) ───────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Groq (free tier available) ────────────────────────────────────
GROQ_API_KEY=

# ── Ollama (local, no key needed) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Default model (used when the frontend sends no model preference) ──
# Format: provider/model-name
DEFAULT_MODEL=openai/gpt-4o-mini
